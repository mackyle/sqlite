#***********************************************************************
# This file implements regression tests for SQLite library.
#

if {![info exists testdir]} {
  set testdir [file join [file dirname [info script]] .. .. test]
} 
source [file join [file dirname [info script]] session_common.tcl]
source $testdir/tester.tcl
ifcapable !session {finish_test; return}

set testprefix sessionrebase2


#-------------------------------------------------------------------------
# Bug https://sqlite.org/bugs/forumpost/70e16d367d
#
set input ""

set rebaser "5401017431001200020000000000000007"

set I [db one {SELECT unhex($input)}]
set R [db one {SELECT unhex($rebaser)}]
do_test 1.0 {
  sqlite3rebaser_create R
  R configure $R
  set I2 [R rebase $I]
  R delete
} {}

finish_test
