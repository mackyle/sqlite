# Tests for "relaxed" quoting
#
do_test 13.2 {
  db eval {
    CREATE TABLE t13(a,b);
    INSERT INTO t13(a,b) VALUES
      (1,'NULL'),
      (0,'-NULL-'),
      (0,''),
      (1,'''abcde'),
      (1,'abcde'''),
      (0,'abcde'),
      (1,' abcde'),
      (1,'abcde '),
      (1,'+0'),
      (1,'-0'),
      (1,'012345'),
      (0,'012xyz345'),
      (1,'0123.45'),
      (0,'12.34.56'),
      (0,'12.3e'),
      (1,'12.3e+123'),
      (1,'12.3e-34'),
      (1,'12.3E56'),
      (1,'12E56'),
      (0,'12.5E5.6'),
      (0,'12.5e+'),
      (0,'12.5e-'),
      (1,'+Inf'),(1,'-Inf'),(1,'Inf');
  }
  set result \n[db format -style box -text relaxed -null NULL \
                 -align {center left} \
                 {SELECT if(a,'yes','') AS 'quoted?', b AS string
                   FROM t13 ORDER BY rowid}]
} {
в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
в”Ӯ quoted? в”Ӯ   string    в”Ӯ
в•һв•җв•җв•җв•җв•җв•җв•җв•җв•җв•Әв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•Ў
в”Ӯ   yes   в”Ӯ 'NULL'      в”Ӯ
в”Ӯ         в”Ӯ -NULL-      в”Ӯ
в”Ӯ         в”Ӯ             в”Ӯ
в”Ӯ   yes   в”Ӯ '''abcde'   в”Ӯ
в”Ӯ   yes   в”Ӯ 'abcde'''   в”Ӯ
в”Ӯ         в”Ӯ abcde       в”Ӯ
в”Ӯ   yes   в”Ӯ ' abcde'    в”Ӯ
в”Ӯ   yes   в”Ӯ 'abcde '    в”Ӯ
в”Ӯ   yes   в”Ӯ '+0'        в”Ӯ
в”Ӯ   yes   в”Ӯ '-0'        в”Ӯ
в”Ӯ   yes   в”Ӯ '012345'    в”Ӯ
в”Ӯ         в”Ӯ 012xyz345   в”Ӯ
в”Ӯ   yes   в”Ӯ '0123.45'   в”Ӯ
в”Ӯ         в”Ӯ 12.34.56    в”Ӯ
в”Ӯ         в”Ӯ 12.3e       в”Ӯ
в”Ӯ   yes   в”Ӯ '12.3e+123' в”Ӯ
в”Ӯ   yes   в”Ӯ '12.3e-34'  в”Ӯ
в”Ӯ   yes   в”Ӯ '12.3E56'   в”Ӯ
в”Ӯ   yes   в”Ӯ '12E56'     в”Ӯ
в”Ӯ         в”Ӯ 12.5E5.6    в”Ӯ
в”Ӯ         в”Ӯ 12.5e+      в”Ӯ
в”Ӯ         в”Ӯ 12.5e-      в”Ӯ
в”Ӯ   yes   в”Ӯ '+Inf'      в”Ӯ
в”Ӯ   yes   в”Ӯ '-Inf'      в”Ӯ
в”Ӯ   yes   в”Ӯ 'Inf'       в”Ӯ
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
}

