do_test 1.80 {
  set result "\n[db format -style insert {SELECT * FROM t1}]"
} {
INSERT INTO tab VALUES(1,2.5,'three');
INSERT INTO tab VALUES(x'424c4f42',NULL,'бјҲОјО®ОҪ');
}
do_test 1.81 {
  set result "\n[db format -style insert -tablename t1 {SELECT * FROM t1}]"
} {
INSERT INTO t1 VALUES(1,2.5,'three');
INSERT INTO t1 VALUES(x'424c4f42',NULL,'бјҲОјО®ОҪ');
}
do_test 1.82 {
  set result "\n[db format -style insert -tablename t1 -title auto \
      {SELECT * FROM t1}]"
} {
INSERT INTO t1(a,b,c) VALUES(1,2.5,'three');
INSERT INTO t1(a,b,c) VALUES(x'424c4f42',NULL,'бјҲОјО®ОҪ');
}
do_test 1.83.0 {
  set result "\n[db format -style insert -tablename drop -title on \
      {SELECT a AS "a-b", b, c AS "123" FROM t1}]"
} {
INSERT INTO "drop"("a-b",b,"123") VALUES(1,2.5,'three');
INSERT INTO "drop"("a-b",b,"123") VALUES(x'424c4f42',NULL,'бјҲОјО®ОҪ');
}
do_test 1.83.1 {
  set result "\n[db format -style insert -tablename drop -title always \
      {SELECT a AS "a-b", b, c AS "123" FROM t1}]"
} {
INSERT INTO "drop"("a-b",b,"123") VALUES(1,2.5,'three');
INSERT INTO "drop"("a-b",b,"123") VALUES(x'424c4f42',NULL,'бјҲОјО®ОҪ');
}
do_test 1.84 {
  set result "\n[db format -style insert {SELECT * FROM t1} -multiinsert 2000]"
} {
INSERT INTO tab VALUES(1,2.5,'three'),
  (x'424c4f42',NULL,'бјҲОјО®ОҪ');
}
do_test 1.85 {
  set result "\n[db format -style insert {
     WITH RECURSIVE c(n) AS (VALUES(1) UNION ALL SELECT n+1 FROM c WHERE n<7)
