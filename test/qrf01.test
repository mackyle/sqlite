do_test 5.4 {
  db eval {
    CREATE TABLE t2(a,b,c,d,e);
    WITH v(x) AS (SELECT 'abcdefghijklmnopqrstuvwxyz')
    INSERT INTO t2 SELECT x,x,x,x,x FROM v;
  }
  set sql {SELECT char(0x61,0xa,0x62,0xa,0x63,0xa,0x64) a,
           mtime b, mtime c, mtime d, mtime e FROM t1}
  set result "\n[db format -style box -widths {1 2 3 4 5}\
                -linelimit 3 -wordwrap off {SELECT *, 'x' AS x FROM t2}]"
} {
в•ӯв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв•®
в”Ӯ a  в”Ӯ b  в”Ӯ  c  в”Ӯ  d   в”Ӯ   e   в”Ӯ x в”Ӯ
в•һв•җв•җв•җв•җв•Әв•җв•җв•җв•җв•Әв•җв•җв•җв•җв•җв•Әв•җв•җв•җв•җв•җв•җв•Әв•җв•җв•җв•җв•җв•җв•җв•Әв•җв•җв•җв•Ў
в”Ӯ ab в”Ӯ ab в”Ӯ abc в”Ӯ abcd в”Ӯ abcde в”Ӯ x в”Ӯ
в”Ӯ cd в”Ӯ cd в”Ӯ def в”Ӯ efgh в”Ӯ fghij в”Ӯ   в”Ӯ
в”Ӯ ef в”Ӯ ef в”Ӯ ghi в”Ӯ ijkl в”Ӯ klmno в”Ӯ   в”Ӯ
в”Ӯ .. в”Ӯ .. в”Ӯ ... в”Ӯ ...  в”Ӯ ...   в”Ӯ   в”Ӯ
в•°в”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв•Ҝ
}

