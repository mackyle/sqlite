#
# Test cases for the Query Result Formatter (QRF)
#

set testdir [file dirname $argv0]
source $testdir/tester.tcl
set testprefix qrf01

do_execsql_test 1.0 {
  CREATE TABLE t1(a, b, c);
  INSERT INTO t1 VALUES(1,2.5,'three'),(x'424c4f42',NULL,'бјҲОјО®ОҪ');
}

do_test 1.10 {
  set result "\n[db format {SELECT * FROM t1}]"
} {
в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
в”Ӯ  a   в”Ӯ  b  в”Ӯ   c   в”Ӯ
в•һв•җв•җв•җв•җв•җв•җв•Әв•җв•җв•җв•җв•җв•Әв•җв•җв•җв•җв•җв•җв•җв•Ў
в”Ӯ    1 в”Ӯ 2.5 в”Ӯ three в”Ӯ
в”Ӯ BLOB в”Ӯ     в”Ӯ бјҲОјО®ОҪ  в”Ӯ
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
}
do_test 1.11.0 {
  set result "\n[db format -title off {SELECT * FROM t1}]"
} {
в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
в”Ӯ    1 в”Ӯ 2.5 в”Ӯ three в”Ӯ
в”Ӯ BLOB в”Ӯ     в”Ӯ бјҲОјО®ОҪ  в”Ӯ
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
}
do_test 1.11.1 {
  set result "\n[db format -text sql {SELECT * FROM t1}]"
} {
в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
в”Ӯ      a      в”Ӯ  b  в”Ӯ    c    в”Ӯ
в•һв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•Әв•җв•җв•җв•җв•җв•Әв•җв•җв•җв•җв•җв•җв•җв•җв•җв•Ў
в”Ӯ           1 в”Ӯ 2.5 в”Ӯ 'three' в”Ӯ
в”Ӯ x'424c4f42' в”Ӯ     в”Ӯ 'бјҲОјО®ОҪ'  в”Ӯ
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
}
do_test 1.11.2 {
  set result "\n[db format -text sql -border off {SELECT * FROM t1}]"
} {
      a      в”Ӯ  b  в”Ӯ    c
в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•Әв•җв•җв•җв•җв•җв•Әв•җв•җв•җв•җв•җв•җв•җв•җв•җ
 1           в”Ӯ 2.5 в”Ӯ 'three'
 x'424c4f42' в”Ӯ     в”Ӯ 'бјҲОјО®ОҪ'
}
do_test 1.11.3 {
  set result "\n[db format -text relaxed -blob sql -border off \
                 {SELECT * FROM t1}]"
} {
      a      в”Ӯ  b  в”Ӯ   c
в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•Әв•җв•җв•җв•җв•җв•Әв•җв•җв•җв•җв•җв•җв•җ
 1           в”Ӯ 2.5 в”Ӯ three
 x'424c4f42' в”Ӯ     в”Ӯ бјҲОјО®ОҪ
}
do_test 1.11.4 {
  set result "\n[db format -rowcount on {SELECT * FROM t1}]"
} {
в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
в”Ӯ  a   в”Ӯ  b  в”Ӯ   c   в”Ӯ
в•һв•җв•җв•җв•җв•җв•җв•Әв•җв•җв•җв•җв•җв•Әв•җв•җв•җв•җв•җв•җв•җв•Ў
в”Ӯ    1 в”Ӯ 2.5 в”Ӯ three в”Ӯ
в”Ӯ BLOB в”Ӯ     в”Ӯ бјҲОјО®ОҪ  в”Ӯ
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
(2 rows)
}
do_test 1.11.5 {
  set result "\n[db format -rowcount on {SELECT * FROM t1 WHERE a=1}]"
} {
в•ӯв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
в”Ӯ a в”Ӯ  b  в”Ӯ   c   в”Ӯ
в•һв•җв•җв•җв•Әв•җв•җв•җв•җв•җв•Әв•җв•җв•җв•җв•җв•җв•җв•Ў
в”Ӯ 1 в”Ӯ 2.5 в”Ӯ three в”Ӯ
в•°в”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
(1 row)
}
do_test 1.11.6 {
  set result "\n[db format {SELECT * FROM t1 WHERE a=2}]"
} {}
do_test 1.11.7 {
  set result "\n[db format -rowcount on {SELECT * FROM t1 WHERE a=2}]"
} {
(0 rows)
}
do_test 1.11.8 {
  set result "\n[db format -title always -rowcount off {SELECT * FROM t1 WHERE a=2}]"
} {
в•ӯв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв•®
в”Ӯ a в”Ӯ b в”Ӯ c в”Ӯ
в•ҳв•җв•җв•җв•§в•җв•җв•җв•§в•җв•җв•җв•ӣ
}
do_test 1.11.9 {
  set result "\n[db format -title always -rowcount on {SELECT * FROM t1 WHERE a=2}]"
} {
в•ӯв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв•®
в”Ӯ a в”Ӯ b в”Ӯ c в”Ӯ
в•ҳв•җв•җв•җв•§в•җв•җв•җв•§в•җв•җв•җв•ӣ
(0 rows)
}

do_test 1.12 {
  set result "\n[db format -text csv {SELECT * FROM t1}]"
} {
в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
в”Ӯ         a          в”Ӯ  b  в”Ӯ   c    в”Ӯ
в•һв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•Әв•җв•җв•җв•җв•җв•Әв•җв•җв•җв•җв•җв•җв•җв•җв•Ў
в”Ӯ                  1 в”Ӯ 2.5 в”Ӯ three  в”Ӯ
в”Ӯ "\102\114\117\102" в”Ӯ     в”Ӯ "бјҲОјО®ОҪ" в”Ӯ
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
}
do_test 1.13 {
  set result "\n[db format -text csv -blob hex {SELECT * FROM t1}]"
} {
в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
в”Ӯ    a     в”Ӯ  b  в”Ӯ   c    в”Ӯ
в•һв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•Әв•җв•җв•җв•җв•җв•Әв•җв•җв•җв•җв•җв•җв•җв•җв•Ў
в”Ӯ        1 в”Ӯ 2.5 в”Ӯ three  в”Ӯ
в”Ӯ 424c4f42 в”Ӯ     в”Ӯ "бјҲОјО®ОҪ" в”Ӯ
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
}
do_test 1.14 {
  catch {db format -text unk -blob hex {SELECT * FROM t1}} res
  set res
} {bad -text "unk": must be auto, csv, html, json, plain, relaxed, sql, or tcl}
do_test 1.15 {
  catch {db format -text sql -blob unk {SELECT * FROM t1}} res
  set res
} {bad BLOB encoding (-blob) "unk": must be auto, hex, json, tcl, text, sql, or size}
do_test 1.16 {
  catch {db format -text sql -style unk {SELECT * FROM t1}} res
  set res
} {bad format style (-style) "unk": must be auto, box, column, count, csv, eqp, explain, html, insert, jobject, json, line, list, markdown, quote, stats, stats-est, stats-vm, or table}
do_test 1.17 {
  catch {db format -text sql -title unk {SELECT * FROM t1}} res
  set res
} {bad -title "unk": must be off, on, always, auto, csv, html, json, plain, relaxed, sql, or tcl}
do_test 1.18 {
  catch {db format -text sql -rowcount unk {SELECT * FROM t1}} res
  set res
} {bad -rowcount "unk": must be auto, yes, no, on, or off}
	
